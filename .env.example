# Base de données TREKKA — PostgreSQL (Neon).
# Copiez ce fichier en .env.local et renseignez votre chaîne de connexion.
# .env.local n'est jamais committé (cf. .gitignore).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret de signature des sessions (HMAC). Générez une valeur aléatoire forte, ex :
#   openssl rand -base64 32
AUTH_SECRET="changez-moi-par-une-valeur-aleatoire-longue"
